<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
      <TargetFrameworks>net472;net48;netcoreapp3.1;net5.0-windows;net6.0-windows;net8.0-windows;</TargetFrameworks>
      <RootNamespace>RFBCodeWorks.Mvvm.WebView2Integration</RootNamespace>
      <AssemblyName>RFBCodeWorks.Mvvm.WebView2Integration</AssemblyName>
      <LangVersion>9.0</LangVersion>
      <Platforms>AnyCPU</Platforms>
      <UseWPF>true</UseWPF>

      
      <!-- Nuget Stuff -->
      <DocumentationFile>$(BaseOutputPath)\$(Configuration)\\$(AssemblyName).xml</DocumentationFile>
      
      <!-- ###################   Version Info ###############  -->
      <Version>1.0.3.0</Version>
      <PackageReleaseNotes>
          - Added UriConverter to convert from URI to string and back
		  Updated Navigation
      </PackageReleaseNotes>
      <!-- #################################  -->
      
      <Configurations>Debug;Release;AppVeyor</Configurations>
      <Description>This is a helper namespace to allow MVVM binding to navigation events generated by the Microsoft WebView2 object

## Example Usage:

xmlns:MyWebView="clr-namespace:RFBCodeWorks.Mvvm.WebView2Integration;assembly=RFBCodeWorks.Mvvm.WebView2Integration"

&lt;grid&gt;

&lt;WebView:WebView2
    x:Name="WV"
    Source="{Binding InitialSource}"
    /&gt;

&lt;MyWebView:WebView2BindingHelper 
    WebView="{Binding ElementName=WV}" 
    NavigationHandler="{Binding NavigationHandler}"/&gt;

&lt;/grid&gt;</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.3537.50" />
  </ItemGroup>
    
	<!-- Enable nuget Packing via Directory.Build.Targets -->
	<PropertyGroup Condition="'$(Configuration)' == 'Release' Or '$(Configuration)' == 'AppVeyor'">
		<PackingEnabled>true</PackingEnabled>
    </PropertyGroup>
	
    <ItemGroup>
        <None Include="Readme.md">
            <PackagePath></PackagePath>
            <Pack>True</Pack>
        </None>
    </ItemGroup>
</Project>
