<UserControl x:Class="ExampleWPF.Views.ComboBoxTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ExampleWPF"
             mc:Ignorable="d" 
             xmlns:md="clr-namespace:MvvmDialogs;assembly=MvvmDialogs"
             xmlns:Behaviors="https://github.com/RFBCodeWorks/MvvmControls/WPF.Behaviors"
            xmlns:Interactions="http://schemas.microsoft.com/xaml/behaviors"
            xmlns:Views="clr-namespace:ExampleWPF.Views"
             xmlns:ViewModels="clr-namespace:ExampleWPF.ViewModels"
        d:DataContext="{d:DesignInstance Type=ViewModels:ComboBoxTester, IsDesignTimeCreatable=True}"
        
             d:DesignHeight="450" d:DesignWidth="800">
    <ScrollViewer ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.CanContentScroll="True" Background="AliceBlue" >
        <StackPanel >
            <GroupBox Header="Enable / Disable Controls ( via Checkbox / RadioButton Definitions )" >
                <StackPanel>
                    <CheckBox Behaviors:ControlDefinitions.CheckBoxDefinition="{Binding EnableComboBox}"/>
                    <Separator Visibility="Hidden" Height="20"/>
                    <RadioButton Behaviors:ControlDefinitions.RadioButtonDefinition="{Binding EnableComboBox}"/>
                    <RadioButton Behaviors:ControlDefinitions.RadioButtonDefinition="{Binding DisableComboBox}"/>
                </StackPanel>
            </GroupBox>
            <GroupBox Header="Refreshable ComboBox Definitions - Source Generated" IsEnabled="{Binding EnableComboBox.IsChecked}">
                <Grid>
                    <Grid.Resources>
                        <Style TargetType="ComboBox">
                            <Setter Property="Grid.Row" Value="3"/>
                            <Setter Property="Margin" Value="15,3,15,0"/>
                            <Setter Property="MinWidth" Value="20"/>
                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                            <Setter Property="VerticalAlignment" Value="Top"/>
                        </Style>
                        <Style TargetType="ListBox">
                            <Setter Property="Grid.Row" Value="3"/>
                            <Setter Property="Margin" Value="15,3,15,0"/>
                            <Setter Property="MinWidth" Value="20"/>
                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                            <Setter Property="VerticalAlignment" Value="Top"/>
                            <Setter Property="MaxHeight" Value="200"/>
                            <Setter Property="MinHeight" Value="50"/>
                        </Style>
                        <Style TargetType="CheckBox">
                            <Setter Property="Grid.Row" Value="2"/>
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="3"/>
                            <Setter Property="IsEnabled" Value="False"/>
                        </Style>
                    </Grid.Resources>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- Headers -->
                    <TextBlock Grid.Row="1" Grid.Column="1"  Text="First Digit : " />
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Second Digit : " />
                    <TextBlock Grid.Row="1" Grid.Column="3" Text="Third Digit : " />
                    <TextBlock Grid.Row="1" Grid.Column="4" Text="Fourth Digit : " />
                    <!-- Checkboxes for isRefreshing -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Is Refreshing : "/>
                    <CheckBox Grid.Column="1" IsChecked="{Binding FirstDigitComboBox.IsRefreshing, Mode=OneWay}"/>
                    <CheckBox Grid.Column="2" IsChecked="{Binding SecondDigitComboBox.IsRefreshing, Mode=OneWay}"/>
                    <CheckBox Grid.Column="3" IsChecked="{Binding ThirdDigitSelector.IsRefreshing, Mode=OneWay}"/>
                    <CheckBox Grid.Column="4" IsChecked="{Binding FourthDigitSelector.IsRefreshing, Mode=OneWay}"/>
                    <Button Grid.Row="3" HorizontalContentAlignment="Center" Content="Refresh&#xA;  First&#xA; Digit" Command="{Binding FirstDigitComboBox.RefreshCommand}"/>
                    <!-- ComboBoxes -->
                    <ComboBox Grid.Column="1" ItemsSource="{Binding FirstDigitComboBox.Items}" SelectedItem="{Binding FirstDigitComboBox.SelectedItem}" />
                    <ComboBox Grid.Column="2" Behaviors:ControlDefinitions.ComboBoxDefinition="{Binding SecondDigitComboBox}" />
                    <ListBox Grid.Column="3" Behaviors:ControlDefinitions.SelectorDefinition ="{Binding ThirdDigitSelector}" />
                    <ListBox Grid.Column="4" Behaviors:ControlDefinitions.SelectorDefinition ="{Binding FourthDigitSelector}" />
                    <TextBlock Grid.Row="4" Grid.ColumnSpan="2" Text="Concatenated Value : "/>
                    <TextBlock Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="3" Text="{Binding ConcatenatedText}"/>
                </Grid>
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
