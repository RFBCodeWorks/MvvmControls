<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <!-- To Do : swap test platforms - unit tests require [STAthread] if run in .net, which is not currently supported -->
        <TargetFrameworks>
            net472;
        </TargetFrameworks>

        <RootNamespace>RFBCodeWorks.Mvvm.Tests</RootNamespace>
        <LangVersion>9.0</LangVersion>
        <IsPackable>false</IsPackable>
        <Configurations>Debug;Release;AppVeyor</Configurations>
        <UseWPF>true</UseWPF>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)' == 'Release' Or '$(Configuration)' == 'AppVeyor'">
        <SignAssembly>True</SignAssembly>
        <AssemblyOriginatorKeyFile>..\..\MvvmControls.snk</AssemblyOriginatorKeyFile>
    </PropertyGroup>
    
    <ItemGroup>
        <PackageReference Include="Microsoft.NET.Test.Sdk" Version="16.9.4" />
        <PackageReference Include="MSTest.TestAdapter" Version="2.2.3" />
        <PackageReference Include="MSTest.TestFramework" Version="2.2.3" />
        <PackageReference Include="coverlet.collector" Version="3.0.2" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\src\Mvvm.Controls\Mvvm.Controls.csproj" />
    </ItemGroup>

    <Choose>
        <When Condition="'$(TargetFramework)' == 'Net472'">
            <!-- Roslyn 311 Testing -->
            <PropertyGroup>
                <DefineConstants>$(DefineConstants);ROSLYN311</DefineConstants>
            </PropertyGroup>

            <ItemGroup>
                <PackageReference Include="Microsoft.CodeAnalysis.Common" Version="3.11.0" PrivateAssets="all" />
                <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="3.11.0" PrivateAssets="all" />
                <ProjectReference Include="..\WittmannUSA.SourceGenerators\WittmannUSA.SourceGenerators.Roslyn311.csproj" />
            </ItemGroup>

        </When>
        <Otherwise>
            <!-- Roslyn 410 Testing -->
            <ItemGroup>
                <PackageReference Include="Microsoft.CodeAnalysis.Common" Version="4.10.0" PrivateAssets="all" />
                <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.10.0" PrivateAssets="all" />
                <ProjectReference Include="..\WittmannUSA.SourceGenerators\WittmannUSA.SourceGenerators.Roslyn410.csproj" />
            </ItemGroup>
        </Otherwise>
    </Choose>

</Project>