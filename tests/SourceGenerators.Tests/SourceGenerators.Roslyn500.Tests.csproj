<?xml version="1.0" encoding="utf-8"?>
<Project>
    <PropertyGroup Label="AnalyzerProps">
        <RoslynTarget>5.00</RoslynTarget>
        <UniqueDirName>$(RoslynTarget)\Tests</UniqueDirName>
        <TargetFrameworks>net48;net10.0-windows;</TargetFrameworks>
    </PropertyGroup>

    <!-- Move the ..\obj directory then explicitly import the SDK -->
    <Import Project=".\SourceGenerators.ImportSdk.Tests.targets" />
    <PropertyGroup>
        <RootNamespace>RFBCodeWorks.Mvvm.SourceGenerators</RootNamespace>
    </PropertyGroup>


    <ItemGroup>
        <Compile Remove=".\**\*Roslyn3*.cs" />
    </ItemGroup>

    <!-- Project to provide the Generated test classes -->
    <ItemGroup>
        <ProjectReference Include="..\..\src\Mvvm.Controls.SourceGenerators\SourceGenerators.Roslyn500.csproj" />
        <ProjectReference Include="SourceGenerators.Tests.Roslyn500.Gen.csproj" />
    </ItemGroup>

    <!-- Nuget Packages for testing -->
    <ItemGroup>
        <PackageReference Include="MSTest" Version="4.1.0" />
        <PackageReference Include="MSTest.TestFramework" Version="4.1.0" />
        <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="5.3.0" PrivateAssets="all" />
    </ItemGroup>

    <!-- Explicitly import the Sdk.targets  -->
    <Import Project="Sdk.targets" Sdk="Microsoft.NET.Sdk" />
</Project>