<?xml version="1.0" encoding="utf-8"?>
<Project>
  <PropertyGroup Label="AnalyzerProps">
      <RoslynTarget>3.11</RoslynTarget>
      <UniqueDirName>$(RoslynTarget)\Tests</UniqueDirName>
      <TargetFrameworks>net472;</TargetFrameworks>
  </PropertyGroup>

  <!-- Move the ..\obj directory then explicitly import the SDK -->
  <Import Project=".\SourceGenerators.ImportSdk.Tests.targets" />
    
  <ItemGroup>
    <Compile Remove=".\**\*Roslyn4*.cs" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove=".\Tests\ButtonTests_Roslyn311.cs" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="Tests\SourceWriterTests.cs" />
  </ItemGroup>

  <ItemGroup>
    <None Include=".\Tests\ButtonTests_Roslyn311.cs" />
  </ItemGroup>
  
    <!-- Project to provide the Generated test classes -->
  <ItemGroup>
    <ProjectReference Include="..\..\src\Mvvm.Controls.SourceGenerators\SourceGenerators.Roslyn311.csproj" />
    <ProjectReference Include="SourceGenerators.Tests.Roslyn311.Gen.csproj" />
  </ItemGroup>

    <!-- Nuget Packages for testing -->
    <ItemGroup>
        <PackageReference Include="MSTest" Version="4.0.1" />
        <PackageReference Include="MSTest.TestFramework" Version="4.0.1" />
        <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="3.11.0" PrivateAssets="all" />
    </ItemGroup>

    <!-- Explicitly import the Sdk.targets  -->
  <Import Project="Sdk.targets" Sdk="Microsoft.NET.Sdk" />
</Project>
