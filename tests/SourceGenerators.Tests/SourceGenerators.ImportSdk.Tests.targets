<?xml version="1.0" encoding="utf-8"?>
<Project>

    <!-- Import the SDK and set file paths -->
    <Import Project=".\SourceGenerators.Tests.Common.targets" />

    <!-- Project Properties -->
    <PropertyGroup>
        <RootNamespace>RFBCodeWorks.Mvvm.SourceGenerators</RootNamespace>
        <IsTestProject>true</IsTestProject>
        <AssemblyName>RFBCodeWorks.Mvvm.SourceGenerators.Test</AssemblyName>
        <UseWPF>true</UseWPF>
    </PropertyGroup>

    <!-- Add any required files -->
    <ItemGroup>
        <Compile Remove=".\Gen\**" />
        <Compile Include=".\Tests\**" />
        <None Include=".\*.Tests.targets" />
    </ItemGroup>

    <!--
    <ItemGroup>
        <Reference Include="RFBCodeWorks.Mvvm.SourceGenerators">
            <HintPath>..\..\src\Mvvm.Controls.SourceGenerators\.bin\$(Configuration)\$(AnalyzerVer)\RFBCodeWorks.Mvvm.SourceGenerators.dll</HintPath>
        </Reference>
    </ItemGroup>
    -->
    
    <ItemGroup>
        <Using Include="Microsoft.VisualStudio.TestTools.UnitTesting" />
    </ItemGroup>

</Project>